            "\u001b[36mCell\u001b[39m\u001b[36m \u001b[39m\u001b[32mIn[23]\u001b[39m\u001b[32m, line 1\u001b[39m\n\u001b[32m----> \u001b[39m\u001b[32m1\u001b[39m missing_df = compute_missing_table(\u001b[43mdf_weather\u001b[49m)\n\u001b[32m      2\u001b[39m total_cells = df_weather.size\n\u001b[32m      3\u001b[39m total_missing = missing_df[\u001b[33m\"\u001b[39m\u001b[33mMissing Count\u001b[39m\u001b[33m\"\u001b[39m].sum()\n",
            "\u001b[31mNameError\u001b[39m: name 'df_weather' is not defined"
          ]
        }
