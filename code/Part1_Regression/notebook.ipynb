        "sig_centers = np.zeros((D, best_sig_M), dtype=float)\n",
        "for d in range(D):\n",
        "    sig_centers[d] = np.quantile(X_train_s[:, d], qs)\n",
        "\n",
        "basis_configs = {\n",
        "    'Linear only': {'poly_degree': None, 'rbf': None, 'sigmoid': None, 'spline': None},\n",
