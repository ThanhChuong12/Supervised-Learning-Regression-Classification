        "        cfg['spline'] = {\n",
        "            'n_knots': int(cfg['spline']['n_knots']),\n",
        "            'degree': int(cfg['spline'].get('degree', 3)),\n",
        "            # transformer intentionally omitted so make_design_matrix refits on Xtr\n",
