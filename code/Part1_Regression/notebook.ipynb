   ],
   "source": [
    "# Tính ma trận tương quan\n",
    "correlation_matrix = df_energy.drop(columns=['date']).corr()\n",
    "\n",
    "# Vẽ heatmap với kích thước lớn\n",
    "plt.figure(figsize=(20, 16))\n",
    "sns.heatmap(correlation_matrix, \n",
